# Hide LeCloud and Service hotline entries, and show AOSP Accounts & sync.

name = "debloat-settings"
description = "Hide the ZuiSettings LeCloud account tile + Service hotline, and always show the AOSP Accounts & sync entry."

[[op]]
kind = "method_const_int"
partition = "system"
file = "system/priv-app/ZuiSettings/ZuiSettings.apk"
class = "Lcom/lenovo/settings/homepage/controller/TopLevelLenovoAccountPreferenceController;"
method = "getAvailabilityStatus"
value = 3

[[op]]
kind = "method_const_int"
partition = "system"
file = "system/priv-app/ZuiSettings/ZuiSettings.apk"
class = "Lcom/android/settings/accounts/TopLevelAccountEntryPreferenceController;"
method = "getAvailabilityStatus"
value = 0

[[op]]
kind = "invoke_const_bool"
partition = "system"
file = "system/priv-app/ZuiSettings/ZuiSettings.apk"
scan_class = "Lcom/lenovo/settings/deviceinfo/controller/LenovoServicePreferenceController;"
target_class = "Lcom/lenovo/common/utils/LenovoUtils;"
target_method = "isPrcVersion"
value = false

[[op]]
kind = "invoke_const_bool"
partition = "system"
file = "system/priv-app/ZuiSettings/ZuiSettings.apk"
scan_class = "Lcom/lenovo/settings/deviceinfo/controller/LenovoServicePreferenceController;"
target_class = "Lcom/lenovo/common/utils/LenovoUtils;"
target_method = "isRowVersion"
value = true
